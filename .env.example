VITE_INTERVALS_ATHLETE_ID=i151223
VITE_INTERVALS_API_KEY=your_api_key_here

# ============================================
# DATA REPOSITORY (Optional)
# ============================================
# Path to external training-logs repository for data/code separation
# If not set, defaults to ~/training-logs
#
# Example (absolute): /Users/your_username/training-logs
# Example (relative): ../training-logs
#
# TRAINING_DATA_REPO=/path/to/training-logs

# ============================================
# AI PROVIDERS (Optional)
# ============================================
# Default provider: clipboard, claude_api, mistral_api, openai, ollama
DEFAULT_AI_PROVIDER=clipboard

# Enable automatic fallback to next available provider
ENABLE_AI_FALLBACK=true

# Claude API (Anthropic)
# CLAUDE_API_KEY=sk-ant-api03-xxxxx
# CLAUDE_MODEL=claude-sonnet-4-20250514

# Mistral AI (Best value: $2-6/1M tokens)
# MISTRAL_API_KEY=xxxxx
# MISTRAL_MODEL=mistral-large-latest

# OpenAI
# OPENAI_API_KEY=sk-xxxxx
# OPENAI_MODEL=gpt-4-turbo-preview

# Ollama (Local LLMs - Recommended: mistral:7b)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=mistral:7b

# ============================================
# ATHLETE PROFILE (Sprint R2)
# ============================================
# Core athlete characteristics that influence training thresholds
# These values are used for personalized training load calculations

ATHLETE_AGE=54
ATHLETE_CATEGORY=master  # Options: junior, senior, master
ATHLETE_RECOVERY_CAPACITY=exceptional  # Options: normal, good, exceptional
ATHLETE_SLEEP_DEPENDENT=true  # Whether performance is strongly sleep-dependent
ATHLETE_FTP=240  # Functional Threshold Power in watts
ATHLETE_WEIGHT=72.5  # Weight in kg

# ============================================
# TRAINING LOAD THRESHOLDS (Sprint R2)
# ============================================
# TSB (Training Stress Balance) thresholds calibrated for this athlete
# TSB = CTL - ATL (Fitness - Fatigue = Form)

TSB_FRESH_MIN=10  # TSB > 10 = fresh state (well rested)
TSB_OPTIMAL_MIN=-5  # -5 < TSB <= 10 = optimal training zone
TSB_FATIGUED_MIN=-15  # -15 < TSB <= -5 = fatigued (manageable)
TSB_CRITICAL=-25  # TSB < -25 = critical overreach risk

# ATL/CTL Ratio thresholds (Fatigue/Fitness ratio)
# Higher ratio = more acute fatigue relative to chronic fitness

ATL_CTL_RATIO_OPTIMAL=1.0  # Ratio < 1.0 = optimal (fitness > fatigue)
ATL_CTL_RATIO_WARNING=1.3  # 1.0 <= ratio < 1.3 = warning zone
ATL_CTL_RATIO_CRITICAL=1.8  # Ratio >= 1.8 = critical fatigue state

# ============================================
# RECOVERY INDICATORS (Sprint R2 - Bonus)
# ============================================
# Thresholds for optional RecoveryAnalyzer feature

RECOVERY_HRV_THRESHOLD_PERCENT=90  # HRV < 90% of baseline = poor recovery
RECOVERY_SLEEP_HOURS_MIN=7.0  # Minimum sleep hours for adequate recovery
RECOVERY_RESTING_HR_DEVIATION_MAX=10  # Max resting HR above baseline (bpm)

# Enable/disable advanced recovery analysis
ENABLE_RECOVERY_ANALYZER=false

# ============================================
# MCP SERVER CONFIGURATION (Hot Reload Support)
# ============================================
# Transport mode: "stdio" (default) or "http"
# - stdio: Standard input/output pipes (Claude Desktop local integration)
# - http: HTTP/SSE transport (enables hot reload with watchdog)
MCP_TRANSPORT=stdio

# HTTP/SSE server configuration (only used if MCP_TRANSPORT=http)
# Configure host and port for HTTP transport mode
MCP_HTTP_HOST=localhost
MCP_HTTP_PORT=3000

# Development mode (enables watchdog auto-restart on code changes)
# Set to 1 in development, 0 in production
# When enabled, watchdog monitors *.py files and restarts server automatically
MCP_DEV_MODE=0
