# ============================================
# INTERVALS.ICU
# ============================================
VITE_INTERVALS_API_KEY=
VITE_INTERVALS_ATHLETE_ID=i151223
VITE_INTERVALS_BASE_URL=https://intervals.icu/api/v1
INTERVALS_ATHLETE_ID=
INTERVALS_API_KEY=

# ============================================
# DATA REPOSITORY
# ============================================
# In Docker, mapped via volume to /data/training-logs
#
# Writer-scoped layout (ADR v5 Phase 1) — multi-writer environments:
# When several agents (Mac, NAS prod, NAS preprod) share the same data repo,
# each writer should write under its own opaque-hash subdir to avoid path
# collisions. Authority per file glob is declared in `.operators.yaml` at the
# repo root. Set TRAINING_DATA_REPO to point at THIS writer's subdir, e.g.:
#
#   - NAS prod    → TRAINING_DATA_REPO=/data/training-logs/88bc132e32a0
#   - NAS preprod → TRAINING_DATA_REPO=/data/training-logs/dd22773d9515
#   - Solo (no multi-writer concern) → TRAINING_DATA_REPO=/data/training-logs
#
# A solo deployment can keep the unscoped form below. Multi-writer deployments
# MUST point at their hash subdir, otherwise startup health-check (PR #298)
# will fail-fast looking for `workouts-history.md` at the wrong path.
TRAINING_DATA_REPO=/data/training-logs
TRAINING_LOGS_PATH=/data/training-logs
INTELLIGENCE_DATA_DIR=

# ============================================
# ATHLETE PROFILE
# ============================================
ATHLETE_AGE=
ATHLETE_CATEGORY=senior
ATHLETE_RECOVERY_CAPACITY=normal
ATHLETE_SLEEP_DEPENDENT=false
ATHLETE_FTP=
ATHLETE_FTP_TARGET=
ATHLETE_WEIGHT=

# ============================================
# AI PROVIDERS
# ============================================
DEFAULT_AI_PROVIDER=mistral_api
ENABLE_AI_FALLBACK=true

# Claude API (Anthropic)
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514

# Mistral AI
MISTRAL_API_KEY=
MISTRAL_MODEL=
MISTRAL_TEMPERATURE=
MISTRAL_MAX_TOKENS=
MISTRAL_TIMEOUT=

# OpenAI (optional)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4-turbo-preview

# Ollama (optional, local LLMs)
OLLAMA_BASE_URL=
OLLAMA_MODEL=

# ============================================
# EMAIL (Brevo)
# ============================================
BREVO_API_KEY=
EMAIL_TO=
EMAIL_FROM=
EMAIL_FROM_NAME=

# ============================================
# MCP TRANSPORT
# ============================================
MCP_TRANSPORT=http
MCP_HTTP_HOST=0.0.0.0
MCP_HTTP_PORT=3000

# ============================================
# GIT (pour push du data repo)
# ============================================
GIT_USER_NAME=stephanejouve
GIT_USER_EMAIL=noreply@github.com
GIT_TOKEN=
GITHUB_TOKEN=

# ============================================
# WITHINGS API (Health data integration)
# ============================================
WITHINGS_CLIENT_ID=
WITHINGS_CLIENT_SECRET=

# ============================================
# mTLS (reverse proxy Nginx)
# ============================================
# Path to directory containing server.crt, server.key, ca.crt
MTLS_CERTS_PATH=
