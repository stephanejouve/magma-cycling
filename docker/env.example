# ============================================
# INTERVALS.ICU
# ============================================
VITE_INTERVALS_API_KEY=
VITE_INTERVALS_ATHLETE_ID=i151223
VITE_INTERVALS_BASE_URL=https://intervals.icu/api/v1
INTERVALS_ATHLETE_ID=
INTERVALS_API_KEY=

# ============================================
# DATA REPOSITORY
# ============================================
# In Docker, mapped via volume to /data/training-logs
TRAINING_DATA_REPO=/data/training-logs
TRAINING_LOGS_PATH=/data/training-logs
INTELLIGENCE_DATA_DIR=

# ============================================
# ATHLETE PROFILE
# ============================================
ATHLETE_AGE=
ATHLETE_CATEGORY=senior
ATHLETE_RECOVERY_CAPACITY=normal
ATHLETE_SLEEP_DEPENDENT=false
ATHLETE_FTP=
ATHLETE_FTP_TARGET=
ATHLETE_WEIGHT=

# ============================================
# AI PROVIDERS
# ============================================
DEFAULT_AI_PROVIDER=mistral_api
ENABLE_AI_FALLBACK=true

# Claude API (Anthropic)
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514

# Mistral AI
MISTRAL_API_KEY=
MISTRAL_MODEL=
MISTRAL_TEMPERATURE=
MISTRAL_MAX_TOKENS=
MISTRAL_TIMEOUT=

# OpenAI (optional)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4-turbo-preview

# Ollama (optional, local LLMs)
OLLAMA_BASE_URL=
OLLAMA_MODEL=

# ============================================
# EMAIL (Brevo)
# ============================================
BREVO_API_KEY=
EMAIL_TO=
EMAIL_FROM=
EMAIL_FROM_NAME=

# ============================================
# MCP TRANSPORT
# ============================================
MCP_TRANSPORT=http
MCP_HTTP_HOST=0.0.0.0
MCP_HTTP_PORT=3000

# ============================================
# GIT (pour push du data repo)
# ============================================
GIT_USER_NAME=stephanejouve
GIT_USER_EMAIL=noreply@github.com
GIT_TOKEN=
GITHUB_TOKEN=

# ============================================
# WITHINGS API (Health data integration)
# ============================================
WITHINGS_CLIENT_ID=
WITHINGS_CLIENT_SECRET=

# ============================================
# mTLS (reverse proxy Nginx)
# ============================================
# Path to directory containing server.crt, server.key, ca.crt
MTLS_CERTS_PATH=
