<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- MAINTENANCE: Project Cleaner - Nettoyage Quotidien -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <!-- Service identifier -->
    <key>Label</key>
    <string>com.cyclisme.mnt.10-project-clean-daily</string>

    <!-- Metadata (documentation) -->
    <key>Description</key>
    <string>Daily maintenance: Clean temporary files and old logs</string>

    <key>Category</key>
    <string>maintenance</string>

    <key>Sequence</key>
    <integer>10</integer>

    <!-- Command to execute -->
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>-c</string>
        <string>cd /Users/stephanejouve/cyclisme-training-logs &amp;&amp; /Users/stephanejouve/.local/bin/poetry run project-clean</string>
    </array>

    <!-- Working directory -->
    <key>WorkingDirectory</key>
    <string>/Users/stephanejouve/cyclisme-training-logs</string>

    <!-- Run at login -->
    <key>RunAtLoad</key>
    <true/>

    <!-- Run once per day (86400 seconds) -->
    <key>StartInterval</key>
    <integer>86400</integer>

    <!-- Logging -->
    <key>StandardOutPath</key>
    <string>/Users/stephanejouve/Library/Logs/cyclisme-mnt-project-clean.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/stephanejouve/Library/Logs/cyclisme-mnt-project-clean.error.log</string>

    <!-- Environment variables -->
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/Users/stephanejouve/.local/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    </dict>

    <!-- Success/failure exit timeout -->
    <key>ExitTimeOut</key>
    <integer>120</integer>

    <!-- Low priority -->
    <key>Nice</key>
    <integer>10</integer>
</dict>
</plist>
