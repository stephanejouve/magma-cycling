# Shift Sessions Aliases
# Source this file in your ~/.zshrc:
#   source ~/cyclisme-training-logs/.zsh_aliases_shift_sessions

# Base shift-sessions command
alias shift='cd ~/cyclisme-training-logs && poetry run shift-sessions'

# Swap operations (rotate/invert sessions)
alias swap-days='cd ~/cyclisme-training-logs && poetry run shift-sessions --swap-days'
alias swap-sessions='cd ~/cyclisme-training-logs && poetry run shift-sessions --swap'

# With sync
alias shift-sync='cd ~/cyclisme-training-logs && poetry run shift-sessions --sync'
alias swap-days-sync='cd ~/cyclisme-training-logs && poetry run shift-sessions --sync --swap-days'
alias swap-sessions-sync='cd ~/cyclisme-training-logs && poetry run shift-sessions --sync --swap'

# Common operations
alias insert-rest='cd ~/cyclisme-training-logs && poetry run shift-sessions --insert-rest-day'
alias remove-session-shift='cd ~/cyclisme-training-logs && poetry run shift-sessions --remove-session'

# Preview (dry-run)
alias shift-preview='cd ~/cyclisme-training-logs && poetry run shift-sessions --dry-run'
alias swap-preview='cd ~/cyclisme-training-logs && poetry run shift-sessions --dry-run --swap-days'
